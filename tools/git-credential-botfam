#!/usr/bin/env bash
#
# git-credential-botfam — a git credential helper that feeds branch pushes to
# the fam's forge using the per-agent token at ~/.botfam/token-<fam>-<actor>,
# so `git push gitea <branch>` "just works" without the inline
#   -c credential.helper='!f(){ echo username=…; echo "password=$(cat …)"; };f'
# dance.
#
# It derives <fam>/<actor> exactly like tools/forge-login.sh (overridable via
# env), authenticates as the forge bot <actor>-bot, and answers ONLY for the
# fam's forge host — so the token is never offered to github.com or any other
# host even if this is installed as a global helper.
#
# Identity (same rules as forge-login.sh):
#   actor : $BOTFAM_ACTOR, else $COLLAB_ACTOR, else this worktree's basename
#           minus a wt-/botfam- prefix.
#   fam   : $BOTFAM_FAM, else the worktree's parent dir name.
#   user  : $BOTFAM_FORGE_USER, else "<actor>-bot".
#   token : $BOTFAM_TOKEN_FILE, else ~/.botfam/token-<fam>-<actor>.
#   forge : $BOTFAM_FORGE_HOST, else the host of `git remote.gitea.url`.
#
# Install (scoped to the forge host, recommended):
#   git config --global credential.http://gitea:3000.helper \
#     /ABS/PATH/tools/git-credential-botfam
# or globally (safe — it self-restricts to the forge host):
#   ln -s /ABS/PATH/tools/git-credential-botfam ~/bin/git-credential-botfam
#   git config --global credential.helper botfam
#
# git invokes it as `git-credential-botfam <op>` with the request on stdin.
# Only `get` is implemented; `store`/`erase` are no-ops (tokens are minted by
# forge-login.sh, not by git).
#
set -euo pipefail
set +x  # never trace — keep the token out of any log

op="${1:-}"
[ "$op" = "get" ] || exit 0  # store/erase/anything else: nothing to do

# --- read git's request (key=value lines, blank line terminates) -------------
req_protocol=""; req_host=""
while IFS= read -r line; do
  [ -z "$line" ] && break
  case "$line" in
    protocol=*) req_protocol="${line#protocol=}" ;;
    host=*)     req_host="${line#host=}" ;;
  esac
done

# --- resolve the fam's forge host (host[:port]) ------------------------------
forge_host="${BOTFAM_FORGE_HOST:-}"
if [ -z "$forge_host" ]; then
  remote_url="$(git config --get remote.gitea.url 2>/dev/null || true)"
  if [ -n "$remote_url" ]; then
    # strip scheme, userinfo, and path → host[:port]
    forge_host="${remote_url#*://}"
    forge_host="${forge_host#*@}"
    forge_host="${forge_host%%/*}"
  fi
fi

# Answer only for our forge host. If we can't determine it, stay silent so git
# falls through to its other helpers rather than risk offering the token wrongly.
[ -n "$forge_host" ] || exit 0
if [ "$req_host" != "$forge_host" ] && [ "$req_host" != "${forge_host%%:*}" ]; then
  exit 0
fi

# --- derive identity (mirrors forge-login.sh) --------------------------------
actor="${BOTFAM_ACTOR:-${COLLAB_ACTOR:-}}"
if [ -z "$actor" ]; then
  actor="$(basename "$PWD")"; actor="${actor#wt-}"; actor="${actor#botfam-}"
fi
fam="${BOTFAM_FAM:-$(basename "$(dirname "$PWD")")}"
user="${BOTFAM_FORGE_USER:-${actor}-bot}"
token_file="${BOTFAM_TOKEN_FILE:-$HOME/.botfam/token-${fam}-${actor}}"

# Missing token: stay silent (let git try other helpers / prompt) rather than error.
[ -r "$token_file" ] || exit 0
token="$(tr -d '\r\n' < "$token_file")"
[ -n "$token" ] || exit 0

# --- emit credentials to git -------------------------------------------------
[ -n "$req_protocol" ] && printf 'protocol=%s\n' "$req_protocol"
printf 'host=%s\n' "$req_host"
printf 'username=%s\n' "$user"
printf 'password=%s\n' "$token"
