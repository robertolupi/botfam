+func TestWikiNormalization(t *testing.T) {
+	t.Run("normalizeWikiResult", func(t *testing.T) {
+		input := []any{
+			map[string]any{
+				"sub_url":  "test-page.-",
+				"html_url": "http://gitea/wiki/test-page.-",
+				"title":    "test-page",
+			},
+			map[string]any{
+				"sub_url":  "clean-page",
+				"html_url": "http://gitea/wiki/clean-page",
+				"title":    "clean-page",
+			},
+		}
+		res := normalizeWikiResult(input)
+		slice, ok := res.([]any)
+		if !ok || len(slice) != 2 {
+			t.Fatalf("expected slice of length 2, got %T", res)
+		}
+		p1 := slice[0].(map[string]any)
+		if p1["sub_url"] != "test-page" {
+			t.Errorf("expected test-page, got %v", p1["sub_url"])
+		}
+		if p1["html_url"] != "http://gitea/wiki/test-page" {
+			t.Errorf("expected clean html_url, got %v", p1["html_url"])
+		}
+	})
+
+	t.Run("getWikiPageFn fallback", func(t *testing.T) {
+		requests := 0
+		srv := httptest.NewServer(http.HandlerFunc(func(w http.ResponseWriter, r *http.Request) {
+			requests++
+			if requests == 1 {
+				w.WriteHeader(http.StatusNotFound)
+				return
+			}
+			w.Header().Set("Content-Type", "application/json")
+			w.WriteHeader(http.StatusOK)
+			_, _ = w.Write([]byte(`{"sub_url":"test-page.-","title":"test-page"}`))
+		}))
+		defer srv.Close()
+
+		origHost := flag.Host
+		flag.Host = srv.URL
+		defer func() { flag.Host = origHost }()
+
+		ctx := context.WithValue(context.Background(), mcpContext.TokenContextKey, "test-token")
+
+		args := map[string]any{
+			"owner":    "org",
+			"repo":     "repo",
+			"pageName": "test-page",
+		}
+
+		req := mcp.CallToolRequest{}
+		req.Params.Arguments = args
+
+		result, err := getWikiPageFn(ctx, req)
+		if err != nil {
+			t.Fatalf("getWikiPageFn error: %v", err)
+		}
+		if result.IsError {
+			t.Fatalf("getWikiPageFn returned error result")
+		}
+
+		if requests != 2 {
+			t.Errorf("expected 2 requests, got %d", requests)
+		}
+
+		var resp map[string]any
+		content := result.Content[0].(mcp.TextContent).Text
+		if err := json.Unmarshal([]byte(content), &resp); err != nil {
+			t.Fatalf("failed to unmarshal result text: %v", err)
+		}
+
+		if resp["sub_url"] != "test-page" {
+			t.Errorf("expected sub_url 'test-page', got %v", resp["sub_url"])
+		}
+	})
+}
