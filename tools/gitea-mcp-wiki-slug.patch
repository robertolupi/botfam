+
+func normalizePage(p map[string]any) {
+	if subURL, ok := p["sub_url"].(string); ok && strings.HasSuffix(subURL, ".-") {
+		p["sub_url"] = strings.TrimSuffix(subURL, ".-")
+	}
+	if htmlURL, ok := p["html_url"].(string); ok && strings.HasSuffix(htmlURL, ".-") {
+		p["html_url"] = strings.TrimSuffix(htmlURL, ".-")
+	}
+}
+
+func normalizeWikiResult(res any) any {
+	if res == nil {
+		return res
+	}
+	switch v := res.(type) {
+	case map[string]any:
+		normalizePage(v)
+	case []any:
+		for _, item := range v {
+			if m, ok := item.(map[string]any); ok {
+				normalizePage(m)
+			}
+		}
+	}
+	return res
+}
